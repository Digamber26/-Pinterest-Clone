<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bootstrap demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/stylesheets/profile.css">
  </head>
  <body>

    <div class="containerpers">
    <div class="cardpers">
      <div class="profile-picture">
        <img src="<%= user.dp ? user.dp : 'https://imgs.search.brave.com/2oI3T50RnGsfKJwDnl3iHwndxwka-0ou-MAfWY4TJaM/rs:fit:500:0:1:0/g:ce/aHR0cHM6Ly90NC5m/dGNkbi5uZXQvanBn/LzA2LzIyLzY5LzE5/LzM2MF9GXzYyMjY5/MTkxMl9VcW5NUUFX/WXhVR2VYQm16ZzJD/RlVkQ0N4Nk1WeUcw/Qi5qcGc' %>" alt="Profile Picture">
      </div>
      <h2 class="name"><%= user.fullname %></h2>
      <h3 class="username">@<%= user.username %></h3>
      <p class="tagline">Welcome to my profile!</p>
      <p class="description">Some things just happen...</p>
      <a href="/logout" class="button">LogOut</a>
    </div>
</div>

<!-- Add Post Form -->
<div class="container" style="margin: 20px auto; max-width: 500px;">
  <h3>Create Pin</h3>
  <form action="/upload" method="post" enctype="multipart/form-data">
    <div class="mb-3">
      <input type="text" name="filecaption" placeholder="Enter caption" class="form-control" required/>
    </div>
    <div class="mb-3">
      <input type="file" name="file" class="form-control" required/>
    </div>
    <button type="submit" class="btn btn-primary">Create Pin</button>
  </form>
</div>

<!-- Posts Section at Bottom -->
<div class="container" style="margin-top: 40px;">
  <h3>Your Pins</h3>
  <div class="cards" style="display: flex; flex-wrap: wrap; gap: 20px;">
    <% if (user.posts && user.posts.length > 0) { %>
      <% user.posts.forEach(function(post){ %>
        <div class="card" style="width: 18rem;">
          <img src="/images/uploads/<%= post.image %>" class="card-img-top" alt="...">
          <div class="card-body">
            <h5 class="card-title"><%= post.imageText %></h5>
            <% const isLiked = currentUser && post.likes && post.likes.some((id) => id.toString() === currentUser._id.toString()); %>
            <% if (currentUser) { %>
              <form action="/posts/<%= post._id %>/like" method="post" class="mt-2">
                <button type="submit" class="btn btn-sm <%= isLiked ? 'btn-danger' : 'btn-outline-danger' %>">
                  <%= isLiked ? '♥ Liked' : '♡ Like' %>
                  <span class="badge text-bg-light"><%= post.likes ? post.likes.length : 0 %></span>
                </button>
              </form>
            <% } else { %>
              <a href="/login" class="btn btn-sm btn-outline-danger mt-2">♡ Like</a>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>