<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feed</title>
    <link rel="stylesheet" href="/stylesheets/feed.css" />
</head>
<body>
    <div class="grid">
        <% if (posts && posts.length > 0) { %>
            <% posts.forEach(function(post){ %>
                <div class="grid__item">
                    <div class="pin-card">
                        <img class="pin-image" src="/images/uploads/<%= post.image %>" alt="<%= post.imageText %>">
                        <div class="pin-meta">
                            <div>
                                <p class="pin-caption"><%= post.imageText %></p>
                                <% if (post.user) { %>
                                    <p class="pin-user">@<%= post.user.username %></p>
                                <% } %>
                            </div>
                            <% const isLiked = currentUser && post.likes.some((id) => id.toString() === currentUser._id.toString()); %>
                            <% if (currentUser) { %>
                                <form action="/posts/<%= post._id %>/like" method="post" class="like-form">
                                    <button type="submit" class="like-btn <%= isLiked ? 'liked' : '' %>">♥ <span><%= post.likes.length %></span></button>
                                </form>
                            <% } else { %>
                                <a href="/login" class="like-btn">♥ <span><%= post.likes.length %></span></a>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <p class="empty-state">No pins yet.</p>
        <% } %>
    </div>
</body>
</html>